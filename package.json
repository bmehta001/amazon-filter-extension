{
  "name": "better-amazon-search",
  "version": "1.0.0",
  "description": "Chrome/Edge extension that adds advanced filters to Amazon search results",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npx playwright test --config playwright.config.ts"
  },
  "keywords": [
    "chrome-extension",
    "amazon",
    "filter",
    "manifest-v3"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.3.0",
    "@playwright/test": "^1.58.2",
    "@types/chrome": "^0.1.37",
    "@types/jsdom": "^28.0.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1"
  }
}
